{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "software-dev@freefly-plugins": true,
    "drone-analytics@freefly-plugins": true,
    "clangd-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "freefly-ai-agent-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/peter/code/freefly-ai-agent-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "permissions": {
    "allow": ["WebFetch"]
  },
  "allowedBashCommands": ["grep", "rg", "find", "ls", "cat", "head", "tail", "wc", "file", "which", "stat", "echo", "pwd"]
}

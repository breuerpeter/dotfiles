{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "Read(/home/peter/code/**)",
      "Read(/home/peter/.config/nvim/**)",
      "Read(/home/peter/documents/wiki/**)",
      "Write(/home/peter/documents/wiki/_ai/**)"
    ],
    "deny": [
      "Read(**/.secrets)",
      "Read(**/.env)"
    ],
    "additionalDirectories": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "software-dev@freefly-plugins": true,
    "drone-analytics@freefly-plugins": true
  },
  "extraKnownMarketplaces": {
    "freefly-plugins": {
      "source": {
        "source": "github",
        "repo": "freefly-systems/freefly-ai-agent-plugins"
      }
    }
  },
  "sandbox": {
    "enabled": false
  },
  "allowedBashCommands": [
    "grep",
    "rg",
    "find",
    "ls",
    "cat",
    "head",
    "tail",
    "wc",
    "file",
    "which",
    "stat",
    "echo",
    "pwd"
  ]
}
